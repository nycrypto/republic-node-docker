# =========================
# Node (REQUIRED)
# =========================

# Docker image for your node (example placeholder)
NODE_IMAGE=REPLACE_ME_WITH_NODE_IMAGE

# RPC endpoint used by the dashboard to query node status
# If the node container exposes 26657 internally, this works:
NODE_RPC_HTTP_URL=http://node:26657

# Optional: expose P2P ports on the host (change to match your node)
NODE_P2P_TCP_PORT=26656
NODE_P2P_UDP_PORT=26656

# =========================
# Dashboard (OPTIONAL)
# =========================
DASHBOARD_PORT=3000

# =========================
# Caddy (RECOMMENDED for public)
# =========================

# Set to your domain (recommended). Example: dashboard.example.com
DASHBOARD_DOMAIN=REPLACE_ME.example.com

# Basic auth (recommended)
DASHBOARD_BASIC_AUTH_USER=admin

# Generate with:
# docker run --rm caddy caddy hash-password --plaintext 'YOUR_PASSWORD'
DASHBOARD_BASIC_AUTH_PASS_HASH=REPLACE_ME_HASH
